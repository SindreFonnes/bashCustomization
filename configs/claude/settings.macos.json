{
  "env": {
    "PATH": "/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
  },
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(ls *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(less *)",
      "Bash(find *)",
      "Bash(ln -s*)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Read(package.json)",
      "Read(README.md)",
      "Read(CLAUDE.md)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git checkout -b *)",
      "Bash(git switch*)",
      "Bash(git restore*)",
      "Bash(cargo run*)",
      "Bash(cargo build*)",
      "Bash(cargo test*)",
      "Bash(cargo check*)",
      "Bash(bun *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(git push --force)",
      "Read(~/.ssh/*)",
      "Read(~/.aws/*)"
    ],
    "ask": [
      "Bash(rm *)"
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "chrome-devtools-plugins": {
      "source": {
        "source": "github",
        "repo": "ChromeDevTools/chrome-devtools-mcp"
      }
    }
  },
  "sandbox": {
    "ripgrep": {
      "command": "/opt/homebrew/bin/rg"
    }
  },
  "effortLevel": "high"
}
