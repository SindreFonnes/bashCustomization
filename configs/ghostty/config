# Config syntax crash course
# ==========================
# # The config file consists of simple key-value pairs,
# # separated by equals signs.
# font-family = Iosevka
# window-padding-x = 2
#
# # Spacing around the equals sign does not matter.
# # All of these are identical:
# key=value
# key= value
# key =value
# key = value
#
# # Any line beginning with a # is a comment. It's not possible to put
# # a comment after a config option, since it would be interpreted as a
# # part of the value. For example, this will have a value of "#123abc":
# background = #123abc
#
# # Empty values are used to reset config keys to default.
# key =
#
# # Some config options have unique syntaxes for their value,
# # which is explained in the docs for that config option.
# # Just for example:
# resize-overlay-duration = 4s 200ms

# 1. Force Option to act as Meta (this is the big one)
macos-option-as-alt = left

# 2. Unbind the specific conflict
# This tells Ghostty "Don't handle this; send it to the shell/Zellij"
keybind = opt+n=unbind
keybind = opt+i=unbind
keybind = opt+h=unbind

# 3. Optional: If you find Cmd + N is also annoying
# keybind = cmd+n=unbind

# Unbind the internal word-jumping so it passes to Zellij
keybind = opt+left=unbind
keybind = opt+right=unbind
keybind = opt+up=unbind
keybind = opt+down=unbind

# Ensure Ghostty doesn't intercept the HJKL combos
keybind = opt+h=unbind
keybind = opt+j=unbind
keybind = opt+k=unbind
keybind = opt+l=unbind
